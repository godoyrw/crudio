# Environment variables for the application
# Copy this file to .env and replace the values with your actual configuration

# Cliente API
CLIENT_ID=example-client-id
CLIENT_API_KEY=your-api-key-here-change-in-production
CLIENT_NAME=Example Client Name

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=example_db
POSTGRES_USER=example_user
POSTGRES_PASSWORD=your-postgres-password-here

# MongoDB
MONGO_ROOT_USERNAME=mongo_root
MONGO_ROOT_PASSWORD=your-mongo-password-here

# Redis
REDIS_PASSWORD=your-redis-password-here

# JWT
JWT_SECRET=your-jwt-secret-key-here-change-to-a-random-string-minimum-32-chars
JWT_ISSUER=ExampleApi
JWT_AUDIENCE=ExampleClient
JWT_EXPIRATION_MINUTES=60
CLIENT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
CLIENT_REFRESH_TOKEN_EXPIRATION_DAYS=30